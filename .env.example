ENV=development
DRY_RUN=true

DATABASE_URL=postgresql+asyncpg://newsbot:newsbot@localhost:5432/newsbot
REDIS_URL=redis://localhost:6379/0

LLM_PROVIDER=anthropic
LLM_MODEL_ANTHROPIC=claude-sonnet-4-5
LLM_MODEL_OPENAI=gpt-4o-mini
LLM_MODEL_GROQ=llama-3.3-70b-versatile
LLM_MODEL_GEMINI=gemini-2.0-flash
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
MAX_ARTICLE_AGE_DAYS=7
MAX_ARTICLES_PER_SOURCE_PER_POLL=10
MAX_STORIES_PER_CYCLE=20
SOURCE_POLL_DELAY_SECONDS=2.0
LLM_CALL_DELAY_SECONDS=3.0

DEDUP_SIMILARITY_THRESHOLD=0.83
CONFIDENCE_THRESHOLD=0.6
BREAKING_CONFIDENCE_THRESHOLD=0.4
IMPORTANCE_THRESHOLD=0.55
RESEARCH_IMPORTANCE_THRESHOLD=0.75
PENDING_STORY_MAX_AGE_HOURS=48
MAX_STORY_AGE_FOR_POSTING_HOURS=24

MAX_TWEETS_PER_DAY=8
MIN_POST_INTERVAL_MINUTES=45
MIN_BREAKING_INTERVAL_MINUTES=10
POLL_INTERVAL_MINUTES=5

ENABLE_STORY_COUNCIL=true
COUNCIL_APPROVAL_THRESHOLD=0.6
COUNCIL_MAX_CANDIDATES_PER_CYCLE=3

TIMEZONE=UTC
LOG_LEVEL=INFO
LOG_FORMAT=console

FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

CELERY_TASK_ALWAYS_EAGER=false
